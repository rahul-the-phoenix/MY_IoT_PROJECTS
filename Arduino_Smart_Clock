// ========== EEPROM FUNCTIONS ==========
void saveAlarmToEEPROM() {
  EEPROM.write(EEPROM_ALARM_HOUR, alarmHour12);
  EEPROM.write(EEPROM_ALARM_MINUTE, alarmMinute);
  EEPROM.write(EEPROM_ALARM_AM, alarmAM ? 1 : 0);
  EEPROM.write(EEPROM_ALARM_ENABLED, alarmEnabled ? 1 : 0);
  EEPROM.write(EEPROM_MAGIC_NUMBER, MAGIC_NUM);
 
  // Optional: Beep to confirm save
  beep(BEEP_BUTTON_FREQ, 50);
}

void loadAlarmFromEEPROM() {
  // Check if valid data exists
  if (EEPROM.read(EEPROM_MAGIC_NUMBER) == MAGIC_NUM) {
    alarmHour12 = EEPROM.read(EEPROM_ALARM_HOUR);
    alarmMinute = EEPROM.read(EEPROM_ALARM_MINUTE);
    alarmAM = EEPROM.read(EEPROM_ALARM_AM) == 1;
    alarmEnabled = EEPROM.read(EEPROM_ALARM_ENABLED) == 1;
   
    // Validate loaded data
    if (alarmHour12 < 1 || alarmHour12 > 12) alarmHour12 = 12;
    if (alarmMinute > 59) alarmMinute = 0;
  }
}

void clearEEPROM() {
  for (int i = 0; i < 10; i++) {
    EEPROM.write(i, 0);
  }
}

// ========== UTILITY FUNCTIONS ==========
void beep(uint16_t freq, uint16_t dur) {
  tone(BUZZER_PIN, freq, dur);
  delay(dur);
  noTone(BUZZER_PIN);
}

void longBeep(uint16_t freq) {
  tone(BUZZER_PIN, freq);
}

bool isBeepSwitchOn() {
  return digitalRead(BEEP_SWITCH_PIN) == LOW;
}

// Precise time update with switch-controlled beep
void updateTimeWithPreciseBeep() {
  static uint8_t lastRTCSecond = 255;
 
  now = rtc.now();
  uint8_t currentSecond = now.second();
 
  if (currentSecond != lastRTCSecond) {
    lastRTCSecond = currentSecond;
    colonState = !colonState;
   
    // Switch-controlled beep at second change (only in default mode)
    if (mode == 0 && isBeepSwitchOn() && currentSecond != lastSecondBeeped) {
      lastSecondBeeped = currentSecond;
      if (now.hour() >= 21 || now.hour() < 6) {
        tone(BUZZER_PIN, BEEP_NIGHT_FREQ, 30);
      } else {
        tone(BUZZER_PIN, BEEP_SECOND_FREQ, 60);
      }
    }
    // If we are in the time static mode, we need to trigger a redraw
    // every minute if we are not using custom graphic digits for HH:MM.
    if (mode == 12 && infoStaticState == 1) {
        displayNeedsUpdate = true;
    }
  }
 
  // Brightness control
  static uint8_t lastBrightnessHour = 255;
  uint8_t currentHour = now.hour();
  if (currentHour != lastBrightnessHour) {
    lastBrightnessHour = currentHour;
    if (currentHour >= 6 && currentHour < 21) {
      display.setIntensity(DAY_BRIGHTNESS);
    } else {
      display.setIntensity(NIGHT_BRIGHTNESS);
    }
  }
}

// ========== DISPLAY FUNCTIONS (Core) ==========

// Update clock display (Mode 0)
void updateDisplayedClockTime() {
  uint8_t hour12 = now.hour() % 12;
  if(hour12 == 0) hour12 = 12;
  uint8_t minute = now.minute();
  uint8_t second = now.second();
 
  if(initialDraw) {
    drawCustomTime(hour12, minute, second, colonState);
    displayedHour12 = hour12;
    displayedMinute = minute;
    displayedSecond = second;
    initialDraw = false;
    return;
  }
 
  // Optimized drawing update
  drawColon(C1_POS, colonState);
  drawColon(C2_POS, colonState);
 
  if(second != displayedSecond) {
    drawDigit(second % 10, S2_POS);
    if(second / 10 != displayedSecond / 10) {
      drawDigit(second / 10, S1_POS);
    }
    displayedSecond = second;
  }
 
  if(minute != displayedMinute) {
    drawDigit(minute % 10, M2_POS);
    if(minute / 10 != displayedMinute / 10) {
      drawDigit(minute / 10, M1_POS);
    }
    displayedMinute = minute;
  }
 
  if(hour12 != displayedHour12) {
    drawDigit(hour12 % 10, H2_POS);
    if(hour12 / 10 != displayedHour12 / 10) {
      drawDigit(hour12 / 10, H1_POS);
    }
    displayedHour12 = hour12;
  }
}

// Update stopwatch display (Mode 9)
void updateDisplayedStopwatchTime(uint8_t hours, uint8_t minutes, uint8_t seconds) {
  if(stopwatchInitialDraw) {
    drawCustomTime(hours, minutes, seconds, colonState);
    displayedStopwatchHours = hours;
    displayedStopwatchMinutes = minutes;
    displayedStopwatchSeconds = seconds;
    stopwatchInitialDraw = false;
    return;
  }
 
  drawColon(C1_POS, colonState);
  drawColon(C2_POS, colonState);
 
  if(seconds != displayedStopwatchSeconds) {
    drawDigit(seconds % 10, S2_POS);
    if(seconds / 10 != displayedStopwatchSeconds / 10) {
      drawDigit(seconds / 10, S1_POS);
    }
    displayedStopwatchSeconds = seconds;
  }
 
  if(minutes != displayedStopwatchMinutes) {
    drawDigit(minutes % 10, M2_POS);
    if(minutes / 10 != displayedStopwatchMinutes / 10) {
      drawDigit(minutes / 10, M1_POS);
    }
    displayedStopwatchMinutes = minutes;
  }
 
  if(hours != displayedStopwatchHours) {
    drawDigit(hours % 10, H2_POS);
    if(hours / 10 != displayedStopwatchHours / 10) {
      drawDigit(hours / 10, H1_POS);
    }
    displayedStopwatchHours = hours;
  }
}

// Update Info Static Display (Mode 12) - NO SCROLL, STATIC TRANSITION (Corrected version)
void updateInfoStaticMode() {
  static uint8_t lastDrawnState = 255;
  static uint8_t lastDisplayedMinute = 255;
  static bool contentNeedsRedraw = true;
 
  // Check if it's time to switch to next state
  if (millis() - lastStateChange >= STATE_INTERVAL || initialDraw) {
    lastStateChange = millis();
    initialDraw = false;
   
    // Cycle to next state (0 -> 1 -> 2 -> 0...)
    infoStaticState = (infoStaticState + 1) % 3;
   
    // Force redraw for new state
    contentNeedsRedraw = true;
    lastDrawnState = 255;
   
    // Clear display only here to prevent flicker between states
    display.displayClear();
    display.getGraphicObject()->clear();
  }
 
  // State 1 (Time) needs periodic update for minute change
  if (infoStaticState == 1) {
    // We update the content only when the minute changes or when the state is newly entered
    if (now.minute() != lastDisplayedMinute) {
      lastDisplayedMinute = now.minute();
      contentNeedsRedraw = true;
    }
  }
 
  // Redraw only when state changes or content needs update
  if (infoStaticState != lastDrawnState || contentNeedsRedraw) {
    lastDrawnState = infoStaticState;
    contentNeedsRedraw = false;
   
    // --- State 0: Date (DD/MM/YY) - GRAPHIC MODE ---
    if (infoStaticState == 0) {
      // Clear graphic buffer for redrawing
      display.getGraphicObject()->clear();
      drawDate(now.day(), now.month(), now.year() % 100);
     
      // NOTE: For static graphic display, no further action is needed here.
    }
    // --- State 1: Time (HH:MM AM/PM) - TEXT MODE (FIXED FONT) ---
    else if (infoStaticState == 1) {
      // Ensure the display is in text mode and clear any previous graphics
      display.displayClear();
      display.setTextAlignment(PA_CENTER);

      uint8_t hour12 = now.hour() % 12;
      if(hour12 == 0) hour12 = 12;
     
      if (now.hour() < 12) {
        snprintf(displayBuffer, 20, "%02d:%02d AM", hour12, now.minute());
      } else {
        snprintf(displayBuffer, 20, "%02d:%02d PM", hour12, now.minute());
      }
     
      display.print(displayBuffer);
    }
    // --- State 2: Day (Text) - TEXT MODE ---
    else if (infoStaticState == 2) {
      // Ensure the display is in text mode and clear any previous graphics
      display.displayClear();
      display.setTextAlignment(PA_CENTER);
     
      const char* days[] = {"Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"};
      display.print(days[now.dayOfTheWeek()]);
    }
  }
}

// ========== BUTTON ACTIONS ==========

void incrementValue() {
  beep(BEEP_BUTTON_FREQ, 30);
  displayNeedsUpdate = true;
 
  switch(mode) {
    case 3:
      alarmHour12 = (alarmHour12 % 12) + 1;
      break;
    case 4:
      alarmMinute = (alarmMinute + 1) % 60;
      break;
    case 5:
      alarmAM = !alarmAM;
      break;
    case 6: stopwatchHours = (stopwatchHours + 1) % 24; break;
    case 7: stopwatchMinutes = (stopwatchMinutes + 1) % 60; break;
    case 8: if(!stopwatchRunning) stopwatchSeconds = (stopwatchSeconds + 1) % 60; break;
  }
}

void decrementValue() {
  beep(BEEP_BUTTON_FREQ, 30);
  displayNeedsUpdate = true;
 
  switch(mode) {
    case 3:
      alarmHour12 = (alarmHour12 == 1) ? 12 : (alarmHour12 - 1);
      break;
    case 4:
      alarmMinute = (alarmMinute == 0) ? 59 : (alarmMinute - 1);
      break;
    case 5:
      alarmAM = !alarmAM;
      break;
    case 6: stopwatchHours = (stopwatchHours == 0) ? 23 : (stopwatchHours - 1); break;
    case 7: stopwatchMinutes = (stopwatchMinutes == 0) ? 59 : (stopwatchMinutes - 1); break;
    case 8: if(!stopwatchRunning) stopwatchSeconds = (stopwatchSeconds == 0) ? 59 : (stopwatchSeconds - 1); break;
  }
}

// Simplified button handler
void handleButton(uint8_t pin, void (*action)()) {
  static unsigned long lastPress[7] = {0};
  uint8_t idx = pin - 2;
 
  if(!digitalRead(pin)) {
    if(millis() - lastPress[idx] > 200) {
      lastPress[idx] = millis();
      action();
    }
    while(!digitalRead(pin)) delay(10);
  }
}

void modeSelectAction() {
  // If currently in TIME OVER mode, stop it and go back to mode 0
  if(mode == 10 || mode == 11) {
    noTone(BUZZER_PIN);
    alarmRinging = false;
    stopwatchOver = false;
    mode = 0;
    initialDraw = true;
    displayNeedsUpdate = true;
    beep(BEEP_BUTTON_FREQ, 100);
    return;
  }

  // Rest of existing mode cycle logic
  if(mode == 0) mode = 1;
  else if(mode == 1) mode = 2;
  else if(mode == 2) {
    mode = 12; // **INFO STATIC DISPLAY**
    infoStaticState = 0; // Start with state 0
    lastStateChange = 0; // Trigger immediate display
    initialDraw = true;
    display.setTextAlignment(PA_CENTER); // Reset alignment
  }
  else if(mode == 12) mode = 0; // **CYCLE BACK TO DEFAULT**
  else mode = 0;

  initialDraw = true;
  displayNeedsUpdate = true;
  beep(BEEP_BUTTON_FREQ, 100);
}

void setConfirmAction() {
  beep(BEEP_BUTTON_FREQ, 250);
  displayNeedsUpdate = true;
 
  switch(mode) {
    case 1:
      mode = 3;
      initialDraw = true;
      break;
    case 2:
      mode = 6;
      stopwatchHours = stopwatchMinutes = stopwatchSeconds = 0;
      initialDraw = true;
      break;
    case 3:
      mode = 4;
      initialDraw = true;
      break;
    case 4:
      mode = 5;
      initialDraw = true;
      break;
    case 5:
      alarmEnabled = true;
      saveAlarmToEEPROM(); // Save alarm to EEPROM
      mode = 0;
      initialDraw = true;
      break;
    case 6:
      mode = 7;
      initialDraw = true;
      break;
    case 7:
      mode = 8;
      initialDraw = true;
      break;
    case 8:
      stopwatchTotalTime = (stopwatchHours * 3600000UL) + (stopwatchMinutes * 60000UL) + (stopwatchSeconds * 1000UL);
      if(stopwatchTotalTime > 0) {
        stopwatchStartTime = millis();
        stopwatchRunning = true;
        stopwatchInitialDraw = true;
        mode = 9;
      }
      break;
    case 9:
      if(stopwatchRunning) {
        unsigned long elapsed = millis() - stopwatchStartTime;
        if(elapsed < stopwatchTotalTime) stopwatchTotalTime -= elapsed;
        stopwatchRunning = false;
        mode = 2;
        initialDraw = true;
      }
      break;
  }
}

void discardAction() {
  beep(BEEP_BUTTON_FREQ, 100);
  delay(100);
   beep(BEEP_BUTTON_FREQ, 100);
  displayNeedsUpdate = true;
 
  if(mode == 10) {
    noTone(BUZZER_PIN);
    alarmRinging = false;
    alarmEnabled = false;  
    saveAlarmToEEPROM(); // Save disabled status
    mode = 0;
    initialDraw = true;
  }
  else if(mode == 11) {
    noTone(BUZZER_PIN);
    stopwatchOver = false;
    mode = 0;
    initialDraw = true;
  }
  else if(mode == 9 && stopwatchRunning) {
    stopwatchRunning = false;
    stopwatchHours = stopwatchMinutes = stopwatchSeconds = 0;
    mode = 2;
    initialDraw = true;
    stopwatchInitialDraw = true;
  }
  else if(mode >= 3 && mode <= 8) {
    mode = 0;
    alarmEnabled = false;
    saveAlarmToEEPROM(); // Save disabled status
    initialDraw = true;
  }
  else if(mode == 1 || mode == 2 || mode == 12) {
    mode = 0;
    initialDraw = true;
  }
  else if(mode == 0 && alarmEnabled) {
    alarmEnabled = false;
    saveAlarmToEEPROM(); // Save disabled status
    initialDraw = true; // Force redraw to show clean time
  }
}

void handleButtons() {
  handleButton(MODE_SELECT_PIN, modeSelectAction);
  handleButton(SET_CONFIRM_PIN, setConfirmAction);
  handleButton(DISCARD_PIN, discardAction);
 
  // Increase/Decrease with long press
  static unsigned long increaseStart = 0, decreaseStart = 0;
  static bool increaseLong = false, decreaseLong = false;
  static unsigned long lastAutoInc = 0, lastAutoDec = 0;
 
  if(!digitalRead(INCREASE_PIN)) {
    if(increaseStart == 0) increaseStart = millis();
    if(!increaseLong && millis() - increaseStart > 1000) {
      increaseLong = true;
      beep(BEEP_BUTTON_FREQ, 100);
    }
    if(increaseLong && millis() - lastAutoInc > 200) {
      lastAutoInc = millis();
      incrementValue();
    }
  } else {
    if(increaseStart > 0 && !increaseLong) incrementValue();
    increaseStart = 0;
    increaseLong = false;
  }
 
  if(!digitalRead(DECREASE_PIN)) {
    if(decreaseStart == 0) decreaseStart = millis();
    if(!decreaseLong && millis() - decreaseStart > 1000) {
      decreaseLong = true;
      beep(BEEP_BUTTON_FREQ, 100);
    }
    if(decreaseLong && millis() - lastAutoDec > 200) {
      lastAutoDec = millis();
      decrementValue();
    }
  } else {
    if(decreaseStart > 0 && !decreaseLong) decrementValue();
    decreaseStart = 0;
    decreaseLong = false;
  }
}

// ========== LOGIC FUNCTIONS ==========

void checkAlarm() {
 
  if(!alarmEnabled) return;
  
 
  if(alarmRinging) return;
 
  uint8_t alarmHour24 = alarmHour12;
  if(alarmAM) {
    if(alarmHour12 == 12) alarmHour24 = 0;
    else alarmHour24 = alarmHour12;
  } else {
    if(alarmHour12 == 12) alarmHour24 = 12;
    else alarmHour24 = alarmHour12 + 12;
  }
 

  if(now.hour() == alarmHour24 && now.minute() == alarmMinute && now.second() == 0) {
    alarmRinging = true;
    timeOverStartTime = millis();
    mode = 10;
    displayNeedsUpdate = true;
    initialDraw = true;
    // Clear display and show TIME OVER immediately
    display.displayClear();
    display.getGraphicObject()->clear();
    longBeep(BEEP_ALARM_FREQ);
  }
}

void updateStopwatch() {
  if(!stopwatchRunning) return;
 
  unsigned long elapsed = millis() - stopwatchStartTime;
  if(elapsed < stopwatchTotalTime) {
    unsigned long remaining = stopwatchTotalTime - elapsed;
    uint8_t hours = remaining / 3600000;
    uint8_t minutes = (remaining % 3600000) / 60000;
    uint8_t seconds = (remaining % 60000) / 1000;
   
    updateDisplayedStopwatchTime(hours, minutes, seconds);
   
    // Switch-controlled beep during stopwatch countdown
    if(isBeepSwitchOn()) {
      static uint8_t lastStopwatchSecond = 255;
      if(seconds != lastStopwatchSecond) {
        lastStopwatchSecond = seconds;
        beep(BEEP_SECOND_FREQ, 60);
      }
    }
  } else {
  
    stopwatchRunning = false;
    stopwatchOver = true;
    timeOverStartTime = millis();
    mode = 11;
    displayNeedsUpdate = true;
    initialDraw = true;
    stopwatchInitialDraw = true;
    
    longBeep(BEEP_STOPWATCH_FREQ);  // ALWAYS beep (switch independent)
  }
}

// Update text display (Used for menu/setting modes 1-8, 10, 11)
void updateTextDisplay() {
  // Always clear when switching to text mode or initial draw
  if(displayNeedsUpdate || initialDraw) {
    display.displayClear();
    display.getGraphicObject()->clear();
  }
 
  switch(mode) {
    case 1:
      if(alarmEnabled) {
        snprintf(displayBuffer, 10, "Alarm-ON");
      } else {
        snprintf(displayBuffer, 10, " Alarm ");
      }
      display.setTextAlignment(PA_CENTER);
      display.print(displayBuffer);
      break;
    case 2:
      snprintf(displayBuffer, 10, "Stopwatch");
      display.setTextAlignment(PA_CENTER);
      display.print(displayBuffer);
      break;
    case 3:
      snprintf(displayBuffer, 10, "Hour: %02d", alarmHour12);
      display.setTextAlignment(PA_CENTER);
      display.print(displayBuffer);
      break;
    case 4:
      snprintf(displayBuffer, 10, "Min: %02d", alarmMinute);
      display.setTextAlignment(PA_CENTER);
      display.print(displayBuffer);
      break;
    case 5:
      snprintf(displayBuffer, 10, "%s", alarmAM ? "AM" : "PM");
      display.setTextAlignment(PA_CENTER);
      display.print(displayBuffer);
      break;
    case 6:
      snprintf(displayBuffer, 10, "Hour: %02d", stopwatchHours);
      display.setTextAlignment(PA_CENTER);
      display.print(displayBuffer);
      break;
    case 7:
      snprintf(displayBuffer, 10, "Min: %02d", stopwatchMinutes);
      display.setTextAlignment(PA_CENTER);
      display.print(displayBuffer);
      break;
    case 8:
      if(!stopwatchRunning) {
        snprintf(displayBuffer, 10, "Sec: %02d", stopwatchSeconds);
        display.setTextAlignment(PA_CENTER);
        display.print(displayBuffer);
      }
      break;
    default:
      // Do nothing for other modes
      break;
  }
 
  displayNeedsUpdate = false;
  initialDraw = false;
}

// Handle Time Over timeout
void handleTimeOverTimeout() {
  if((mode == 10 || mode == 11) && (millis() - timeOverStartTime > 180000)) {
    if(mode == 10) {
      noTone(BUZZER_PIN);
      alarmRinging = falseো;
    } else {
      noTone(BUZZER_PIN);
      stopwatchOver = false;
    }
    mode = 0;
    initialDraw = true;
    displayNeedsUpdate = true;
  }
}

// ========== SETUP ==========
void setup() {
  Wire.begin();
 
  // Load saved alarm from EEPROM
  loadAlarmFromEEPROM();
 
  // Initialize RTC
  if(!rtc.begin()) {
    while(1) {
      tone(BUZZER_PIN, 1500, 200);
      delay(1000);
    }
  }
 
  if(rtc.lostPower()) {
    // rtc.adjust(DateTime(F(__DATE__), F(__TIME__)));
  }
 
  // Initialize Display
  display.begin();
  display.setSpeed(0); // No scrolling speed
  display.setPause(0); // No pause between animation steps
  display.setTextAlignment(PA_CENTER);
  display.setIntensity(DAY_BRIGHTNESS);
  display.displayClear();
 
  // Pin Setup
  pinMode(BUZZER_PIN, OUTPUT);
  pinMode(MODE_SELECT_PIN, INPUT_PULLUP);
  pinMode(SET_CONFIRM_PIN, INPUT_PULLUP);
  pinMode(INCREASE_PIN, INPUT_PULLUP);
  pinMode(DECREASE_PIN, INPUT_PULLUP);
  pinMode(DISCARD_PIN, INPUT_PULLUP);
  pinMode(BEEP_SWITCH_PIN, INPUT_PULLUP);
 
  now = rtc.now();
  lastSecondBeeped = now.second();
 
  // Startup beep and show alarm status
  for(int i=0; i<2; i++) {
    beep(BEEP_SECOND_FREQ, 100);
    delay(200);
  }
 
  // Show alarm status briefly if enabled
  if(alarmEnabled) {
    display.setTextAlignment(PA_CENTER);
    display.print("Alarm-ON");
    delay(1000);
    display.displayClear();
  }
}

// ========== MAIN LOOP ==========
void loop() {
  updateTimeWithPreciseBeep();
 
  handleButtons();
 
  static unsigned long lastUpdate = 0;
  // Use a faster update rate for stopwatch/colon animation
  if (millis() - lastUpdate >= 50) {
    lastUpdate = millis();
   
    checkAlarm();
   
    if (mode == 9) {
      updateStopwatch();
    }
    else if (mode == 0 && stopwatchRunning) {
      // If somehow stopwatch is running but we're not in mode 9
      updateStopwatch();
    }
   
    handleTimeOverTimeout();
  }
 
  // --- DISPLAY CONTROL ---
 
  if (mode == 0) {
    // Default 6-digit clock mode
    updateDisplayedClockTime();
    display.displayAnimate();
  }
  else if(mode == 12) {
    // Info Static Mode (Date -> Time -> Day)
    // The state logic within updateInfoStaticMode handles redrawing
    updateInfoStaticMode();
    display.displayAnimate();
  }
  else if (mode == 9) {
    // Stopwatch Running (Custom Digits)
    // updateStopwatch handles the drawing (via updateDisplayedStopwatchTime)
    display.displayAnimate();
  }
  else if (mode == 10 || mode == 11) {
    if (digitalRead(BUZZER_PIN) == HIGH) { 
      // Blinking "TIME OVER"
      if (colonState) {
        display.setTextAlignment(PA_CENTER);
        display.print("TIME UP");
      } else {
        display.setTextAlignment(PA_CENTER);
        display.print("         "); // Blank screen
      }
    } else { ো
      display.displayClear();
    }
    display.displayAnimate();
  }
  else {
    // Text-based modes (Alarm Menu, Stopwatch Menu, Set Modes)
    if(displayNeedsUpdate || initialDraw) {
      updateTextDisplay();
    }
    display.displayAnimate();
  }
}
