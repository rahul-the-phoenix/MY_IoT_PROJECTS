// ========== DIGIT DRAWING FUNCTIONS ==========
#define DIGIT_WIDTH 6
#define TOTAL_COLS (MAX_DEVICES * 8) // 6 * 8 = 48

// Positions for digits and colons
#define H1_POS 1    // Hour/1st-group tens
#define H2_POS 8    // Hour/1st-group ones
#define C1_POS 15   // First colon/slash
#define M1_POS 18   // Minute/2nd-group tens
#define M2_POS 25   // Minute/2nd-group ones
#define C2_POS 32   // Second colon/slash (SS or YY)
#define S1_POS 35   // Second/3rd-group tens
#define S2_POS 42   // Second/3rd-group ones

// Mirror fix for FC16_HW display
uint8_t mapCol(uint8_t col) {
  return (TOTAL_COLS - 1) - col;
}

// Draw a single digit
void drawDigit(uint8_t digit, uint8_t startCol) {
  if (digit > 9) return;
 
  for (uint8_t row = 0; row < 8; row++) {
    uint8_t rowData = pgm_read_byte(&lcdDigits[digit][row]);
    for (uint8_t col = 0; col < DIGIT_WIDTH; col++) {
      bool pixel = (rowData >> (DIGIT_WIDTH - col)) & 0x01;
      display.getGraphicObject()->setPoint(row, mapCol(startCol + col), pixel);
    }
  }
}

// Draw/clear colon
void drawColon(uint8_t col, bool state) {
  display.getGraphicObject()->setPoint(2, mapCol(col), state);
  display.getGraphicObject()->setPoint(5, mapCol(col), state);
}

// Draw complete time (Used for Mode 0 - HH:MM:SS)
void drawCustomTime(uint8_t g1, uint8_t g2, uint8_t g3, bool showColon) {
  display.getGraphicObject()->clear();
 
  // Group 1 (HH / DD)
  drawDigit(g1 / 10, H1_POS);
  drawDigit(g1 % 10, H2_POS);
  drawColon(C1_POS, showColon);
 
  // Group 2 (MM / MM)
  drawDigit(g2 / 10, M1_POS);
  drawDigit(g2 % 10, M2_POS);
  drawColon(C2_POS, showColon);
 
  // Group 3 (SS / YY)
  drawDigit(g3 / 10, S1_POS);
  drawDigit(g3 % 10, S2_POS);
}

// Draw slash for date format
void drawSlash(uint8_t col) {
  display.getGraphicObject()->setPoint(1, mapCol(col), true);
  display.getGraphicObject()->setPoint(2, mapCol(col), true);
  display.getGraphicObject()->setPoint(3, mapCol(col), false);
  display.getGraphicObject()->setPoint(4, mapCol(col), false);
  display.getGraphicObject()->setPoint(5, mapCol(col), true);
  display.getGraphicObject()->setPoint(6, mapCol(col), true);
}

// Draw date with slashes (DD/MM/YY)
void drawDate(uint8_t day, uint8_t month, uint8_t year) {
  display.getGraphicObject()->clear();
 
  // Day
  drawDigit(day / 10, H1_POS);
  drawDigit(day % 10, H2_POS);
 
  // Slash 1
  drawSlash(C1_POS);
 
  // Month
  drawDigit(month / 10, M1_POS);
  drawDigit(month % 10, M2_POS);
 
  // Slash 2
  drawSlash(C2_POS);
 
  // Year
  drawDigit(year / 10, S1_POS);
  drawDigit(year % 10, S2_POS);
}

